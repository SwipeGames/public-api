{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "../..",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "index.ts",
    "../../api/v1.0/core/api.gen.ts",
    "../../api/v1.0/core/api.gen.zod.ts",
    "../../api/v1.0/swipegames-integration/api.gen.ts",
    "../../api/v1.0/swipegames-integration/api.gen.zod.ts"
  ]
}
